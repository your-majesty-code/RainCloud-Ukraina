# RainCloud Ukraina — environment template.
# Copy to .env.local and fill with your Supabase project values.
# Settings → API in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key — used ONLY by local seeding scripts, never shipped to the browser.
# (Optional; the app itself runs on the anon key + RLS read policies.)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps (Network → Map view). Without a key the map shows a placeholder
# and the member list still works.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-js-api-key
# Optional: a styled Map ID (defaults to Google's DEMO_MAP_ID in dev).
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your-map-id
